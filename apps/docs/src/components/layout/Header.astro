---
import { ThemeToggle } from '../ui/ThemeToggle';
import SearchTrigger from '../ui/SearchTrigger.astro';
import { PhoneIcon, GithubIcon } from '../ui/HeaderIcons';
---

<header
  class="fixed inset-x-0 top-0 z-50 h-16 border-b border-separator/50 bg-bg/80 backdrop-blur-xl backdrop-saturate-150"
>
  <div class="h-full max-w-[1400px] mx-auto px-4 sm:px-6 flex items-center justify-between">
    <div class="flex items-center gap-4">
      <a
        href="/"
        class="group flex items-center gap-2.5 text-[17px] font-semibold text-label transition-colors"
        aria-label="phoneng home"
      >
        <div class="relative flex items-center justify-center w-9 h-9 rounded-xl bg-accent transition-transform duration-300 group-hover:scale-105">
          <PhoneIcon client:load />
        </div>
        <span class="hidden sm:inline font-display">phoneng</span>
      </a>
      <span class="hidden sm:inline-flex items-center px-2.5 py-1 rounded-full bg-success/15 text-success text-xs font-mono font-medium">
        v1.0.0
      </span>
    </div>

    <nav class="flex items-center gap-1" aria-label="Header navigation">
      <a
        href="/docs/getting-started"
        class="hidden sm:inline-flex items-center h-9 px-4 rounded-lg text-[14px] font-medium font-display text-secondary-label hover:text-label hover:bg-fill transition-colors"
      >
        Docs
      </a>
      <a
        href="/playground"
        class="hidden sm:inline-flex items-center h-9 px-4 rounded-lg text-[14px] font-medium font-display text-secondary-label hover:text-label hover:bg-fill transition-colors"
      >
        Playground
      </a>
      
      <div class="w-px h-5 bg-separator mx-2 hidden sm:block"></div>
      
      <SearchTrigger />
      <ThemeToggle client:load />
      <a
        href="https://github.com/nicholasgriffintn/phoneng"
        target="_blank"
        rel="noopener noreferrer"
        class="flex h-9 w-9 items-center justify-center rounded-lg text-secondary-label transition-colors hover:bg-fill hover:text-label"
        aria-label="View on GitHub"
      >
        <GithubIcon client:load />
      </a>
    </nav>
  </div>
</header>
