---
interface Props {
  type?: 'info' | 'warning' | 'danger' | 'tip';
  title?: string;
}

const { type = 'info', title } = Astro.props;

const styles = {
  info: {
    border: 'border-accent',
    bg: 'bg-accent/[0.08]',
    title: 'text-accent',
    icon: `<circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/>`,
  },
  warning: {
    border: 'border-warning',
    bg: 'bg-warning/[0.08]',
    title: 'text-warning',
    icon: `<path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3"/><path d="M12 9v4"/><path d="M12 17h.01"/>`,
  },
  danger: {
    border: 'border-danger',
    bg: 'bg-danger/[0.08]',
    title: 'text-danger',
    icon: `<circle cx="12" cy="12" r="10"/><path d="m15 9-6 6"/><path d="m9 9 6 6"/>`,
  },
  tip: {
    border: 'border-success',
    bg: 'bg-success/[0.08]',
    title: 'text-success',
    icon: `<path d="M15 14c.2-1 .7-1.7 1.5-2.5 1-.9 1.5-2.2 1.5-3.5A6 6 0 0 0 6 8c0 1 .2 2.2 1.5 3.5.7.7 1.3 1.5 1.5 2.5"/><path d="M9 18h6"/><path d="M10 22h4"/>`,
  },
};

const style = styles[type];
---

<div
  class:list={[
    'my-4 rounded-medium border-l-[3px] p-3 pl-4',
    style.border,
    style.bg,
  ]}
  role="note"
>
  <div class="flex items-start gap-3">
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="18"
      height="18"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      class:list={['mt-0.5 shrink-0', style.title]}
      aria-hidden="true"
    >
      <Fragment set:html={style.icon} />
    </svg>
    <div class="min-w-0 flex-1">
      {
        title && (
          <p class:list={['mb-1 text-[13px] font-semibold', style.title]}>
            {title}
          </p>
        )
      }
      <div class="text-[13px] text-secondary-label [&>p:last-child]:mb-0">
        <slot />
      </div>
    </div>
  </div>
</div>
